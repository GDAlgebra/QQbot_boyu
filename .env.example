# Public OneBot / NapCat HTTP API address.
# GitHub Actions cannot access localhost on your own computer.
ONEBOT_HTTP_URL=https://your-public-onebot-api.example.com
ONEBOT_ACCESS_TOKEN=

# private = private chat, group = group chat
QQ_TARGET_TYPE=private
QQ_TARGET_ID=123456789

# X source. Usually setting X_USERNAME is enough.
X_USERNAME=nico_nico_news
X_RSS_URL=

# 0 = first run only records the latest post, 1 = first run also sends it.
SEND_FIRST_RUN=0

# Local preview/testing.
DRY_RUN=0
MANUAL_MESSAGE=
